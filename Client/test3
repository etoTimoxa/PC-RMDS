def main():
    """Главная функция"""
    cloud = CloudManager()
    
    if not cloud.s3:
        print("❌ Не удалось подключиться к облаку")
        return
    
    while True:
        print_menu()
        choice = input("Выберите действие: ").strip()
        
        if choice == '0':
            print("👋 До свидания!")
            break
        
        elif choice == '1':
            cloud.show_files()
        
        elif choice == '2':
            result = cloud.delete_all_files(confirm=True)
            print(f"\n📊 Результат: удалено {result['success']}, ошибок {result['failed']}")
        
        elif choice == '3':
            pattern = input("Введите паттерн (regex) для поиска: ").strip()
            if pattern:
                result = cloud.delete_by_pattern(pattern, confirm=True)
                print(f"\n📊 Результат: удалено {result['success']}, ошибок {result['failed']}")
            else:
                print("❌ Паттерн не может быть пустым")
        
        elif choice == '4':
            date_str = input("Введите дату (YYYY-MM-DD): ").strip()
            if date_str:
                result = cloud.delete_by_date(date_str, confirm=True)
                print(f"\n📊 Результат: удалено {result['success']}, ошибок {result['failed']}")
            else:
                print("❌ Дата не может быть пустой")
        
        elif choice == '5':
            file_name = input("Введите имя файла: ").strip()
            if file_name:
                if cloud.delete_file(file_name):
                    print("✅ Файл удален")
                else:
                    print("❌ Не удалось удалить файл")
            else:
                print("❌ Имя файла не может быть пустым")
        
        elif choice == '6':
            cloud.check_connection()
        
        else:
            print("❌ Неверный выбор. Попробуйте снова.")


if __name__ == "__main__":
    main()