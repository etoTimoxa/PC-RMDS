import boto3
from botocore.config import Config
from pathlib import Path

# ==================== НАСТРОЙКИ ====================
ACCESS_KEY = "1TUFGD6LDS8S8DGRFYMU"
SECRET_KEY = "Vq3kZWM8HSxcxZNv4qLw9l63J80mj9fBsd80KumS"
ENDPOINT_URL = "https://s3.regru.cloud"
BUCKET_NAME = "metrics-errors-logs"

# ПРАВИЛЬНЫЙ полный путь к папке metric
SOURCE_FOLDER = r"C:\Users\Тимофей\Desktop\metric"

# ==================== ПОДКЛЮЧЕНИЕ ====================
s3 = boto3.client(
    's3',
    endpoint_url=ENDPOINT_URL,
    aws_access_key_id=ACCESS_KEY,
    aws_secret_access_key=SECRET_KEY,
    config=Config(signature_version='s3v4')
)

# ==================== ПРОВЕРКА ПАПКИ ====================
folder = Path(SOURCE_FOLDER)

print(f"Проверяем папку: {SOURCE_FOLDER}")
print(f"Папка существует: {folder.exists()}")

if not folder.exists():
    print("❌ Папка не найдена! Проверьте путь.")
    exit()

# ==================== ЗАГРУЗКА ФАЙЛОВ ====================
# Находим все JSON файлы
json_files = list(folder.glob("*.json"))

print(f"\nНайдено JSON файлов: {len(json_files)}")
print("=" * 50)

if len(json_files) == 0:
    print("⚠️ Нет JSON файлов в папке. Показываю все файлы в папке:")
    all_files = list(folder.iterdir())
    for f in all_files:
        if f.is_file():
            print(f"   - {f.name}")
else:
    for file_path in json_files:
        object_name = file_path.name
        file_size = file_path.stat().st_size / 1024  # размер в KB
        
        print(f"📤 Загрузка: {object_name} ({file_size:.1f} KB)")
        try:
            s3.upload_file(str(file_path), BUCKET_NAME, object_name)
            print(f"   ✅ {object_name} - загружен")
        except Exception as e:
            print(f"   ❌ {object_name}: {e}")

print("=" * 50)
print("Готово!")